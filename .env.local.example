# Copy this file to .env.local and fill in the values below.
#
# Setup order:
#   1. Run `pnpm dlx convex dev` once. Log in and create a new deployment.
#      This writes CONVEX_DEPLOYMENT and VITE_CONVEX_URL into your .env.local
#      automatically.
#   2. Create a Clerk application at https://dashboard.clerk.com
#      - Copy the publishable key into VITE_CLERK_PUBLISHABLE_KEY
#      - Copy the secret key into CLERK_SECRET_KEY
#   3. In Clerk, create a new JWT Template named `convex` (required by
#      ConvexProviderWithClerk). Copy its Issuer URL.
#   4. In the Convex dashboard → Settings → Authentication, add a new provider
#      with the Clerk Issuer URL and applicationID. See
#      https://docs.convex.dev/auth/clerk for details.

# Convex (populated by `pnpm dlx convex dev`)
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# WhatsApp Cloud API (Meta) — used for shopper-facing messaging only
# (cart handoff replies, status updates). Retailer alerts now go via email.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Email (Resend) — retailer-facing operational notifications
#   1. Sign up at https://resend.com and create an API key
#   2. Verify your sender domain (e.g. kedaipal.com) in the Resend dashboard
#      before deploying. Until verified, sends will fail with a 4xx and
#      retailers receive nothing — the action swallows the error and logs it.
#   3. EMAIL_FROM should match a verified sender on your domain.
RESEND_API_KEY=
EMAIL_FROM=Kedaipal Orders <orders@kedaipal.com>
